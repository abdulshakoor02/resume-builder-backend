# Server
PORT=8080

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=resume_builder

# Nextcloud WebDAV (optional)
# NEXTCLOUD_BASE_URL=https://cloud.example.com/remote.php/dav/files/USERNAME
# NEXTCLOUD_USERNAME=admin
# NEXTCLOUD_PASSWORD=app-password
# NEXTCLOUD_SHARE_BASE_URL=https://cloud.example.com/s

# LLM — any OpenAI-compatible API
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1   # optional, defaults to OpenAI
# LLM_BASE_URL=https://openrouter.ai/api/v1 # OpenRouter
# LLM_BASE_URL=http://localhost:11434/v1    # Ollama
# LLM_BASE_URL=https://api.groq.com/openai/v1 # Groq

# JWT
JWT_SECRET=change-me-to-a-random-string
